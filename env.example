# MoeGate 环境变量（与 config/settings.py AppConfig 一一对应）
# 复制为 .env 后按需修改；带「可选」注释的变量可留空或使用默认值

# ============================================
# API 服务基础配置
# ============================================
# 是否启用内置 Web UI 管理面板
ENABLE_WEBUI=True

# WebUI Basic 认证（可选；两者均配置时启用，建议生产环境配置）
# WEBUI_BASIC_AUTH_USER=admin
# WEBUI_BASIC_AUTH_PASSWORD=change-me

# 公开 Prometheus 指标端点 GET /metrics（启用后须同时配置 METRICS_TOKEN）
ENABLE_PUBLIC_METRICS=false

# /metrics 访问令牌（可选；ENABLE_PUBLIC_METRICS 或配置 METRICS_TOKEN 时端点可见）
# METRICS_TOKEN=

# API 服务监听端口（对应 AppConfig.PORT）
API_PORT=8080

# API 监听地址（0.0.0.0 监听所有网卡；生产请配合防火墙限制来源 IP）
API_HOST=0.0.0.0

# 调试模式（生产必须 False，避免泄露异常信息）
API_DEBUG=False

# ============================================
# 容器调度与资源限制
# ============================================
MAX_TIME=3600
MAX_CONTAINERS=30
MAX_RENEW_TIMES=3

# 多实例共享 ALLOWED_BASE_DIR 时，通过文件锁协调容器名额预留
ENABLE_SHARED_QUOTA=true

# 容器随机映射端口范围（须满足 MAX_PORT - MIN_PORT >= MAX_CONTAINERS）
MIN_PORT=20000
MAX_PORT=30000

# 进程关闭时是否销毁所有受管容器（生产建议 false）
SHUTDOWN_DESTROY_CONTAINERS=false

# 容器到期 reconcile 扫描间隔（秒）
EXPIRE_RECONCILE_INTERVAL_SEC=60

# 容器资源限制
CONTAINER_MEMORY_LIMIT=512m
CONTAINER_CPU_LIMIT=1.0
CONTAINER_CPU_SHARES=1024

# 全局镜像仓库前缀（可选）
# IMAGE_SOURCE=registry.example.com/mirror

# 允许挂载/构建的根目录白名单（必填）
ALLOWED_BASE_DIR=/var/containers

# 容器 env 注入上限
MAX_CONTAINER_ENV_KEYS=64
MAX_CONTAINER_ENV_VALUE_LEN=4096

# 禁用 Docker 凭证助手（部分环境可避免镜像拉取权限异常）
DISABLE_DOCKER_CREDENTIALS=False

# ============================================
# Compose SDK 编排（非 docker compose CLI）
# ============================================
COMPOSE_MANAGED_SUBNET_POOL=172.30.0.0/16
COMPOSE_MANAGED_SUBNET_PREFIX=24

# ctf（默认，允许 privileged / bind mount）| strict（拒绝高危配置）
COMPOSE_POLICY=ctf

# 永久不支持字段的处理：warn（日志 + API compose_warnings）| error（拒绝启动）
COMPOSE_UNSUPPORTED=warn

# ============================================
# Web UI 前端配置
# ============================================
# WebUI 调用后端 API 的基础地址（可选；留空则使用相对路径）
# WEBUI_API_BASE=http://127.0.0.1:8080

WEBUI_POLL_INTERVAL_SEC=30

# 多 worker 时启用运行态设置文件共享（默认 false）
# RUNTIME_STORE_PERSIST=false

# ============================================
# API 认证、Session 与 CSRF
# ============================================
# API 密钥（必填，>=32 字符，不可用默认占位值）
API_KEY=your_secret_api_key

# Cookie Session（默认启用）
ENABLE_API_SESSION_COOKIE=true
# Session 签名密钥（必填，且必须与 API_KEY 不同）
API_SESSION_SECRET=your_session_signing_secret
API_SESSION_COOKIE_NAME=moegate_session
API_SESSION_TTL_SEC=86400
# HTTPS 生产环境应设为 true
API_SESSION_COOKIE_SECURE=false
# SameSite：Lax | Strict | None
API_SESSION_COOKIE_SAMESITE=Lax

# CSRF（Cookie 模式下变更类 API，默认启用）
ENABLE_API_CSRF=true
API_CSRF_COOKIE_NAME=moegate_csrf
API_CSRF_HEADER_NAME=X-CSRF-Token

# ============================================
# 限流、超时与 SSE
# ============================================
RATE_LIMIT_PER_MIN=60
RATE_LIMIT_MAX_TRACKED_KEYS=10000
RATE_LIMIT_GC_INTERVAL_SECONDS=30
AUTH_FAILURE_LIMIT_PER_MIN=10
REQUEST_TIMEOUT=30

# SSE 流式构建/拉取日志限制
SSE_MAX_LOG_LINE_LENGTH=2000
SSE_MAX_LOG_EVENTS=2000

# 运行态 WebUI 设置是否禁止超过 .env 启动值
LOCK_RUNTIME_QUOTA_TO_BOOT=true

# ============================================
# 反向代理与 CORS
# ============================================
# 启用时须配置 TRUSTED_PROXY_IPS
TRUST_PROXY_HEADERS=False
# 可信反代来源 IP/CIDR（逗号分隔）
TRUSTED_PROXY_IPS=
# CORS 白名单（逗号分隔；留空不允许跨域）
CORS_ALLOWED_ORIGINS=

# ============================================
# 告警 Webhook
# ============================================
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_TIMEOUT=5

# ============================================
# FRP 内网穿透
# ============================================
ENABLE_FRP=False
FRP_SERVER_ADDR=
FRP_SERVER_PORT=7000
FRP_ADMIN_IP=127.0.0.1
FRP_ADMIN_PORT=7400
FRP_ADMIN_USER=
FRP_ADMIN_PASSWORD=
FRP_LOCAL_IP=127.0.0.1
FRP_USE_DOMAIN=False
FRP_DOMAIN_SUFFIX=
FRP_VHOST_HTTP_PORT=

# ============================================
# 日志
# ============================================
# 留空时根据 API_DEBUG 自动决定
LOG_LEVEL=
LOG_FORMAT=text
LOG_FILE=
LOG_MAX_SIZE=10MB
LOG_BACKUP_COUNT=5
