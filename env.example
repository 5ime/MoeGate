# ============================================
# API 服务基础配置
# ============================================
# 是否启用内置 Web UI 管理面板
ENABLE_WEBUI=True

# API 服务监听端口
API_PORT=8080

# API 监听地址
# 生产环境建议 0.0.0.0，本地开发可用 127.0.0.1
API_HOST=0.0.0.0

# 调试模式开关
# 生产环境必须设为 False，避免泄露异常信息
API_DEBUG=False

# ============================================
# 容器调度与资源限制
# ============================================
# 单容器最大运行时长（秒）
MAX_TIME=3600

# 系统允许同时运行的最大容器数量
MAX_CONTAINERS=30

# 容器随机映射端口范围
# 建议 >=1024，避免与系统端口冲突
MIN_PORT=20000
MAX_PORT=30000

# 容器允许的最大续期次数
MAX_RENEW_TIMES=3

# 容器内存限制
# 格式示例：512m、1g、2g
CONTAINER_MEMORY_LIMIT=512m

# 允许挂载/构建的根目录白名单
# 用于防止目录越权访问，生产环境必填且谨慎配置
ALLOWED_BASE_DIR=/var/containers

# 容器 CPU 核心限制（留空表示不限制）
CONTAINER_CPU_LIMIT=1.0

# 容器 CPU 权重（Docker cpu-shares）
# 值越高，容器在资源竞争时优先级越高
CONTAINER_CPU_SHARES=1024

# 全局镜像仓库前缀（可选）
# 用于内网镜像加速，如 registry.example.com/mirror
# IMAGE_SOURCE=registry.example.com/mirror

# ============================================
# 运行时动态配置
# ============================================
# 是否允许通过 API 接口动态修改当前 .env 配置
# 生产环境建议关闭，防止误操作
ALLOW_RUNTIME_CONFIG_WRITE=False

# ============================================
# Web UI 前端配置
# ============================================
# WebUI 调用后端 API 的基础地址
# 留空则使用相对路径，前后端分离时需指定完整地址
# WEBUI_API_BASE=http://127.0.0.1:8080

# WebUI 前端轮询刷新状态间隔（秒）
WEBUI_POLL_INTERVAL_SEC=30

# ============================================
# API 安全与限流
# ============================================
# API 接口鉴权密钥
# 所有 /api/v1/* 接口需在请求头携带 X-API-Key
# 生产环境必须替换为强随机密钥
API_KEY=your_secret_api_key

# 单 IP 每分钟最大请求数（接口限流）
RATE_LIMIT_PER_MIN=60

# 外部请求通用超时时间（秒）
REQUEST_TIMEOUT=30

# 限流模块最多跟踪的 IP/Key 数量
RATE_LIMIT_MAX_TRACKED_KEYS=10000

# 限流状态垃圾回收清理周期（秒）
RATE_LIMIT_GC_INTERVAL_SECONDS=30

# SSE 流式日志长度与条数限制
SSE_MAX_LOG_LINE_LENGTH=2000
SSE_MAX_LOG_EVENTS=2000

# 是否信任反向代理（Nginx/Traefik）传递的真实 IP 等请求头
# 启用前确保代理层可信，防止 IP 伪造
TRUST_PROXY_HEADERS=False

# CORS 跨域白名单（逗号分隔，多个域名用英文逗号隔开）
# 留空表示不允许任何跨域请求
# 示例：https://panel.example.com,https://admin.example.com
CORS_ALLOWED_ORIGINS=

# 禁用 Docker 凭证助手
# 部分环境下可避免镜像拉取权限异常
DISABLE_DOCKER_CREDENTIALS=False

# 容器销毁失败重试耗尽后的告警 webhook
ALERT_WEBHOOK_URL=

# 告警请求超时时间（秒）
ALERT_WEBHOOK_TIMEOUT=5
#
# CPU 告警（当启用性能监控时，可按阈值触发 Webhook）
# 触发阈值（百分比）
ALERT_CPU_THRESHOLD=95
# 连续多少个采样区间超阈值才触发
ALERT_CPU_SUSTAINED_INTERVALS=3

#
# 内存告警（当启用性能监控时，可按阈值触发 Webhook）
# 触发阈值（百分比）
ALERT_MEM_THRESHOLD=90
# 连续多少个采样区间超阈值才触发
ALERT_MEM_SUSTAINED_INTERVALS=3

# 告警冷却时间（秒），冷却内不重复告警
ALERT_COOLDOWN_SEC=900

# ============================================
# FRP 内网穿透配置
# ============================================
# 是否启用 FRP 内网穿透
ENABLE_FRP=False

# FRP 服务端地址
FRP_SERVER_ADDR=

# FRP 服务端端口
FRP_SERVER_PORT=7000

# FRP 客户端管理面板地址
FRP_ADMIN_IP=127.0.0.1

# FRP 客户端管理端口
FRP_ADMIN_PORT=7400

# FRP 管理面板登录账号（可选）
FRP_ADMIN_USER=

# FRP 管理面板登录密码（可选）
FRP_ADMIN_PASSWORD=

# 是否使用域名模式（HTTP 虚拟主机）
FRP_USE_DOMAIN=False

# 自动分配子域名的后缀
# 示例：container.example.com
FRP_DOMAIN_SUFFIX=

# FRP 服务端 vhost HTTP 端口
FRP_VHOST_HTTP_PORT=

# ============================================
# 日志配置
# ============================================
# 日志输出级别
# 可选：DEBUG/INFO/WARNING/ERROR/CRITICAL
# 留空时自动根据 API_DEBUG 决定级别
LOG_LEVEL=

# 日志文件路径（启用文件日志时填写）
LOG_FILE=

# 单个日志文件最大大小
LOG_MAX_SIZE=10MB

# 最大保留的日志归档文件数量
LOG_BACKUP_COUNT=5

# ============================================
# 性能监控
# ============================================
# 是否启用系统性能监控
# 记录 CPU、内存、运行容器数等指标
ENABLE_PERFORMANCE_MONITORING=False

# 性能指标采样间隔（秒）
PERFORMANCE_LOG_INTERVAL=300